rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidRoom(data) {
      return data.number is string && data.number.size() <= 50 &&
             data.type is string && data.type.size() <= 50 &&
             data.priceTier is number && data.priceTier >= 0 &&
             data.status is string && data.status.matches('^(AVAILABLE|OCCUPIED|DIRTY|MAINTENANCE|BOOKED)$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Room collection
    match /rooms/{roomId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(roomId);
      allow create: if isSignedIn() && isValidId(roomId) && isValidRoom(incoming());
      allow update: if isSignedIn() && isValidId(roomId) && isValidRoom(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['number', 'type', 'priceTier', 'status']);
      allow delete: if isSignedIn() && isValidId(roomId);
    }

    // Guest collection
    match /guests/{guestId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(guestId);
      allow create: if isSignedIn() && isValidId(guestId);
      allow update: if isSignedIn() && isValidId(guestId);
      allow delete: if isSignedIn() && isValidId(guestId);
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(bookingId);
      allow create: if isSignedIn() && isValidId(bookingId);
      allow update: if isSignedIn() && isValidId(bookingId);
      allow delete: if isSignedIn() && isValidId(bookingId);
    }
    
    // Booking History collection
    match /bookingHistory/{bookingId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(bookingId);
      allow create: if isSignedIn() && isValidId(bookingId);
    }

    // Users collection
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 255 &&
             data.role is string && data.role.size() <= 10;
    }
    function isUserRole(uid, role) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
             get(/databases/$(database)/documents/users/$(uid)).data.role == role;
    }
    function isAdmin(uid) {
        return isUserRole(uid, 'ADMIN');
    }
    function isDevAdmin() {
        return isSignedIn() && (request.auth.token.email == 'agbonghaeidemudia@gmail.com' || request.auth.token.email == 'admin@gmail.com');
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin(request.auth.uid) || isDevAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (isAdmin(request.auth.uid) || isDevAdmin()) && isValidUser(incoming());
      allow list: if isSignedIn() && (isAdmin(request.auth.uid) || isDevAdmin());
    }
  }
}
